NODE_ENV=development
PORT=3000

JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1d

POSTGRES_DB=hybrid_api
POSTGRES_USER=hybrid_user
POSTGRES_PASSWORD=hybrid_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://hybrid_user:hybrid_password@postgres:5432/hybrid_api

MONGO_INITDB_ROOT_USERNAME=mongo_user
MONGO_INITDB_ROOT_PASSWORD=mongo_password
MONGO_INITDB_DATABASE=hybrid_api
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_URI=mongodb://mongo_user:mongo_password@mongo:27017/hybrid_api?authSource=admin

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
